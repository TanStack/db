{
  "name": "offline-first-electron",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "main": "electron/main.ts",
  "scripts": {
    "dev": "concurrently \"pnpm dev:renderer\" \"pnpm dev:server\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:server": "tsx server/index.ts",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "server": "tsx server/index.ts",
    "postinstall": "prebuild-install --runtime electron --target 40.2.1 --arch arm64 || echo 'prebuild-install failed, try: npx @electron/rebuild'"
  },
  "dependencies": {
    "@tanstack/electron-db-sqlite-persistence": "^0.1.9",
    "@tanstack/node-db-sqlite-persistence": "^0.1.9",
    "@tanstack/offline-transactions": "^1.0.30",
    "@tanstack/query-db-collection": "^1.0.36",
    "@tanstack/react-db": "^0.1.83",
    "@tanstack/react-query": "^5.100.9",
    "better-sqlite3": "^12.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "electron": "^40.9.3",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.2",
    "wait-on": "^8.0.5"
  }
}
