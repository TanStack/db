{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@tanstack/db": ["../db/src"],
      "@tanstack/db-ivm": ["../db-ivm/src"],
      "@tanstack/db-sqlite-persistence-core": [
        "../db-sqlite-persistence-core/src"
      ]
    }
  },
  "include": [
    "src",
    "tests",
    "e2e/**/*.ts",
    "vite.config.ts",
    "vitest.e2e.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "e2e/app/dist",
    "e2e/app/src-tauri/target"
  ]
}
