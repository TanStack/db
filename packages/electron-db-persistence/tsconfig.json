{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "paths": {
      "@tanstack/db": ["../db/src"],
      "@tanstack/db-ivm": ["../db-ivm/src"],
      "@tanstack/node-db-persistence": ["../node-db-persistence/src"],
      "@tanstack/db-persistence-core": ["../db-persistence-core/src"]
    }
  },
  "include": [
    "src",
    "tests/**/*.test.ts",
    "tests/**/*.test-d.ts",
    "vite.config.ts",
    "vitest.e2e.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
